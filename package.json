{
  "name": "twitch-stream-swap",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/extension",
    "packages/segment-analyzer"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:shared": "npm run build -w packages/shared",
    "build:extension": "npm run build -w packages/extension",
    "build:analyzer": "npm run build -w packages/segment-analyzer",
    "clean": "npm run clean --workspaces"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}

{
  "manifest_version": 3,
  "name": "Prime Video広告スキッパー",
  "version": "0.0.0",
  "description": "Prime Video広告スキップ",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.amazon.co.jp/*",
    "*://*.amazon.com/*",
    "*://*.primevideo.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.co.jp/*",
        "*://*.amazon.com/*",
        "*://*.primevideo.com/*"
      ],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Prime Video広告スキッパー",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}

{
  "manifest_version": 3,
  "name": "еєѓе‘Љг‚№г‚­гѓѓгѓ‘гѓј",
  "version": "0.2.0",
  "description": "Twitchеєѓе‘Љг‚№гѓЇгѓѓгѓ— + Prime Videoеєѓе‘Љг‚№г‚­гѓѓгѓ—",
  "permissions": [
    "webRequest",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.hls.ttvnw.net/*",
    "*://*.ttvnw.net/*",
    "*://*.cloudfront.net/*",
    "*://*.twitch.tv/*",
    "*://*.amazon.co.jp/*",
    "*://*.amazon.com/*",
    "*://*.primevideo.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["content/content-script.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["page/page-script.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://*.amazon.co.jp/*",
        "*://*.amazon.com/*",
        "*://*.primevideo.com/*"
      ],
      "js": ["content/prime-content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "devtools_page": "devtools/devtools.html",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "еєѓе‘Љг‚№г‚­гѓѓгѓ‘гѓј",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
